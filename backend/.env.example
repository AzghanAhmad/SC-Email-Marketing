# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Config binding uses the double-underscore convention: AmazonSes__AccessKeyId -> AmazonSes:AccessKeyId

# --- Amazon SES credentials ---
AmazonSes__AccessKeyId=your-aws-access-key-id
AmazonSes__SecretAccessKey=your-aws-secret-access-key

# --- JWT signing key (min 32 chars) ---
Jwt__Key=change-me-to-a-long-random-secret-at-least-32-chars

# --- Optional: override the database connection string ---
# ConnectionStrings__DefaultConnection=Server=127.0.0.1;Port=3306;Database=scribecount_email;User=root;Password=;SslMode=None;
